{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/SteCiu01/Fabric-Agentic-Workspace-One-Click-Setup/main/schema/agent-manifest.schema.json",
  "title": "Fabric Agentic Workspace - Agent Manifest",
  "description": "Schema for the agent manifest embedded in Setup-FabricAgenticWorkspace.ps1 (the $agentManifestJson here-string). CI extracts that JSON and validates it against this file.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "productVersion", "defaults", "agents"],
  "properties": {
    "schemaVersion": { "type": "integer", "minimum": 1 },
    "productVersion": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "defaults": {
      "type": "object",
      "additionalProperties": true,
      "required": ["mode", "tools"],
      "properties": {
        "mode": { "type": "string" },
        "tools": {
          "type": "array",
          "items": { "$ref": "#/definitions/tool" },
          "uniqueItems": true
        }
      }
    },
    "agents": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/agent" }
    }
  },
  "definitions": {
    "tool": {
      "type": "string",
      "enum": ["agent", "read", "search", "execute", "edit"]
    },
    "agent": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "displayName",
        "filename",
        "level",
        "department",
        "parent",
        "allowedChildren",
        "visibility",
        "userInvocable",
        "tools",
        "focus"
      ],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
        "displayName": { "type": "string", "minLength": 1 },
        "filename": { "type": "string", "pattern": "^\\d+-[a-z0-9-]+\\.agent\\.md$" },
        "level": { "type": "string", "enum": ["executive", "team-lead", "worker"] },
        "department": { "type": "string", "minLength": 1 },
        "parent": { "type": ["string", "null"] },
        "allowedChildren": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "visibility": { "type": "string", "enum": ["visible", "hidden"] },
        "userInvocable": { "type": "boolean" },
        "tools": {
          "type": "array",
          "items": { "$ref": "#/definitions/tool" },
          "uniqueItems": true
        },
        "primarySkills": { "type": "array", "items": { "type": "string" } },
        "conditionalSkills": { "type": "array", "items": { "type": "string" } },
        "artifactTypes": { "type": "array", "items": { "type": "string" } },
        "writePermissions": { "type": "string" },
        "defaultRisk": { "type": "string", "enum": ["low", "medium", "high"] },
        "optionalToolRequestPermissions": { "type": "string" },
        "focus": { "type": "string", "minLength": 1 }
      }
    }
  }
}
